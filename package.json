{
  "name": "clm-stats.app",
  "version": "1.0.0",
  "repository": "git@github.com:clm-stats/clm-stats.app.git",
  "author": "Mitch Dzugan <mitchdzugan@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev:mkhtml": "node -e 'require(\"fs\").writeFileSync(__dirname + \"/index.html\", require(\"./js/htmlDocTemplate.js\").default())'",
    "dev:start": "vite dev",
    "dev": "run-s dev:mkhtml dev:start",
    "dev:gh-db": "cross-env CLM_STATS_APP_FORCE_PROXY=yes run-s dev"
  },
  "alias": {
    "react": "preact/compat",
    "react-dom/test-utils": "preact/test-utils",
    "react-dom": "preact/compat",
    "react/jsx-runtime": "preact/jsx-runtime"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "fuzzysort": "^3.1.0",
    "preact": "^10.28.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/postcss": "^4.2.1",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "http-proxy-middleware": "^3.0.5",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.16.4",
    "static-server": "^2.2.1",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animated": "^2.0.0",
    "vite": "^7.3.1"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
